{
  "version": 2,
  "name": "lumyn",

  "routes": [
    { "src": "/",            "dest": "/diamond-platform.html"        },
    { "src": "/portal",      "dest": "/lumyn-chatroom-ordering.html" },
    { "src": "/order",       "dest": "/lumyn-chatroom-ordering.html" },
    { "src": "/chat",        "dest": "/lumyn-chatroom-ordering.html" },
    { "src": "/track",       "dest": "/lumyn-chatroom-ordering.html" },
    { "src": "/feed",        "dest": "/lumyn-community-feed.html"    },
    { "src": "/community",   "dest": "/lumyn-community-feed.html"    },
    { "src": "/(.*)",        "dest": "/diamond-platform.html"        }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "DENY"                          },
        { "key": "X-XSS-Protection",       "value": "1; mode=block"                 },
        { "key": "X-Content-Type-Options", "value": "nosniff"                       },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "Cache-Control",          "value": "public, max-age=3600"          }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
